{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "local>JacobPEvans/.github:renovate-presets",
  ],
  "nix": {
    "enabled": true,
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 7am on Monday"],
  },
  "packageRules": [
    {
      "description": "Group MLX Python packages into a single PR",
      "matchManagers": ["pep621"],
      "matchFileNames": ["mlx-server/**"],
      "groupName": "mlx-packages",
    },
    {
      "description": "Group Orchestrator Python packages into a single PR",
      "matchManagers": ["pep621"],
      "matchFileNames": ["orchestrator/**"],
      "groupName": "orchestrator-packages",
    },
    {
      "description": [
        "30-day stabilization hold for manually pinned MLX packages — see",
        "lib/versions.nix comments and nix-ai#751. mlx 0.31.2 introduced",
        "thread-local stream semantics that break vllm-mlx's scheduler thread,",
        "so we rolled back to mlx 0.31.1 + mlx-lm 0.31.2. Holding 30 days gives",
        "upstream time to ship a fix (vllm-mlx per-thread generation_stream",
        "init, or MLX cross-thread visibility restored) before Renovate proposes",
        "the next bump. Removal is tracked in nix-ai#762 — close that issue and",
        "delete this rule once the upstream regression is resolved.",
      ],
      "matchDatasources": ["pypi"],
      "matchPackageNames": ["mlx", "mlx-lm", "mlx-metal"],
      "minimumReleaseAge": "30 days",
      "automerge": false,
    },
  ],
}
